ANTHROPIC_API_KEY=your_key_here

# Stripe test mode -- get from dashboard.stripe.com (test mode toggle)
STRIPE_TEST_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Circle Programmable Wallets -- Phase 8 real USDC settlement
# Get from developers.circle.com (free, use Sandbox mode)
# Without these, the USDC rail falls back to simulation (Phase 4 behavior)
CIRCLE_API_KEY=TEST_API_KEY:...
CIRCLE_BUYER_WALLET_ID=your_circle_wallet_id_here
